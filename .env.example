# Configurações do Servidor de Impressão
FLASK_APP=server.py
FLASK_ENV=development
PORT=5000
HOST=0.0.0.0

# Configurações de Impressão
# Nome da impressora no Windows exatamente como aparece no Painel de Controle
DEFAULT_PRINTER="Nome Da Impressora Aqui"

# Caminho para o SumatraPDF (deixe vazio para usar a versão embutida em ./SumatraPDF/SumatraPDF.exe)
SUMATRA_PATH=
